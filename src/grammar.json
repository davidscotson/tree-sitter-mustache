{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "mustache",
  "rules": {
    "template": {
      "type": "REPEAT",
      "content": {
        "type": "SYMBOL",
        "name": "_declaration"
      }
    },
    "_declaration": {
      "type": "SYMBOL",
      "name": "_statement"
    },
    "comment_statement": {
      "type": "SEQ",
      "members": [
        {
          "type": "ALIAS",
          "content": {
            "type": "SYMBOL",
            "name": "start_delimiter"
          },
          "named": true,
          "value": "_start_delimiter"
        },
        {
          "type": "STRING",
          "value": "!"
        },
        {
          "type": "ALIAS",
          "content": {
            "type": "SYMBOL",
            "name": "_comment_content"
          },
          "named": true,
          "value": "comment_content"
        },
        {
          "type": "ALIAS",
          "content": {
            "type": "SYMBOL",
            "name": "end_delimiter"
          },
          "named": true,
          "value": "_end_delimiter"
        }
      ]
    },
    "_statement": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "comment_statement"
        },
        {
          "type": "SYMBOL",
          "name": "triple_statement"
        },
        {
          "type": "SYMBOL",
          "name": "ampersand_statement"
        },
        {
          "type": "SYMBOL",
          "name": "section"
        },
        {
          "type": "SYMBOL",
          "name": "inverted_section"
        },
        {
          "type": "SYMBOL",
          "name": "block_statement"
        },
        {
          "type": "SYMBOL",
          "name": "parent_partial_statement"
        },
        {
          "type": "SYMBOL",
          "name": "partial_statement"
        },
        {
          "type": "SYMBOL",
          "name": "interpolation_statement"
        },
        {
          "type": "SYMBOL",
          "name": "text"
        }
      ]
    },
    "interpolation_statement": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "start_delimiter"
        },
        {
          "type": "SYMBOL",
          "name": "_expression"
        },
        {
          "type": "SYMBOL",
          "name": "end_delimiter"
        }
      ]
    },
    "triple_statement": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "start_delimiter"
        },
        {
          "type": "STRING",
          "value": "{"
        },
        {
          "type": "SYMBOL",
          "name": "_expression"
        },
        {
          "type": "STRING",
          "value": "}"
        },
        {
          "type": "SYMBOL",
          "name": "end_delimiter"
        }
      ]
    },
    "ampersand_statement": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "start_delimiter"
        },
        {
          "type": "STRING",
          "value": "&"
        },
        {
          "type": "SYMBOL",
          "name": "_expression"
        },
        {
          "type": "SYMBOL",
          "name": "end_delimiter"
        }
      ]
    },
    "partial_statement": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "start_delimiter"
        },
        {
          "type": "STRING",
          "value": ">"
        },
        {
          "type": "ALIAS",
          "content": {
            "type": "SYMBOL",
            "name": "_start_tag_name"
          },
          "named": true,
          "value": "partial_content"
        },
        {
          "type": "SYMBOL",
          "name": "end_delimiter"
        }
      ]
    },
    "parent_partial_statement": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "parent_partial_begin"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "_statement"
          }
        },
        {
          "type": "ALIAS",
          "content": {
            "type": "SYMBOL",
            "name": "_section_end"
          },
          "named": true,
          "value": "parent_partial_end"
        }
      ]
    },
    "parent_partial_begin": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "start_delimiter"
        },
        {
          "type": "STRING",
          "value": "<"
        },
        {
          "type": "ALIAS",
          "content": {
            "type": "SYMBOL",
            "name": "_start_tag_name"
          },
          "named": true,
          "value": "partial_content"
        },
        {
          "type": "SYMBOL",
          "name": "end_delimiter"
        }
      ]
    },
    "block_statement": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "block_begin"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "_statement"
          }
        },
        {
          "type": "ALIAS",
          "content": {
            "type": "SYMBOL",
            "name": "_section_end"
          },
          "named": true,
          "value": "block_end"
        }
      ]
    },
    "block_begin": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "start_delimiter"
        },
        {
          "type": "STRING",
          "value": "$"
        },
        {
          "type": "ALIAS",
          "content": {
            "type": "SYMBOL",
            "name": "_start_tag_name"
          },
          "named": true,
          "value": "block_name"
        },
        {
          "type": "SYMBOL",
          "name": "end_delimiter"
        }
      ]
    },
    "section": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "section_begin"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "_statement"
          }
        },
        {
          "type": "ALIAS",
          "content": {
            "type": "SYMBOL",
            "name": "_section_end"
          },
          "named": true,
          "value": "section_end"
        }
      ]
    },
    "_section_end": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "start_delimiter"
        },
        {
          "type": "STRING",
          "value": "/"
        },
        {
          "type": "ALIAS",
          "content": {
            "type": "SYMBOL",
            "name": "_end_tag_name"
          },
          "named": true,
          "value": "tag_name"
        },
        {
          "type": "SYMBOL",
          "name": "end_delimiter"
        }
      ]
    },
    "section_begin": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "start_delimiter"
        },
        {
          "type": "STRING",
          "value": "#"
        },
        {
          "type": "ALIAS",
          "content": {
            "type": "SYMBOL",
            "name": "_start_tag_name"
          },
          "named": true,
          "value": "tag_name"
        },
        {
          "type": "SYMBOL",
          "name": "end_delimiter"
        }
      ]
    },
    "inverted_section": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "inverted_section_begin"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "_statement"
          }
        },
        {
          "type": "ALIAS",
          "content": {
            "type": "SYMBOL",
            "name": "_section_end"
          },
          "named": true,
          "value": "inverted_section_end"
        }
      ]
    },
    "inverted_section_begin": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "start_delimiter"
        },
        {
          "type": "STRING",
          "value": "^"
        },
        {
          "type": "ALIAS",
          "content": {
            "type": "SYMBOL",
            "name": "_start_tag_name"
          },
          "named": true,
          "value": "tag_name"
        },
        {
          "type": "SYMBOL",
          "name": "end_delimiter"
        }
      ]
    },
    "_expression": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "path_expression"
        },
        {
          "type": "SYMBOL",
          "name": "identifier"
        },
        {
          "type": "STRING",
          "value": "."
        }
      ]
    },
    "identifier": {
      "type": "SYMBOL",
      "name": "_identifier_content"
    },
    "path_expression": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "identifier"
        },
        {
          "type": "REPEAT1",
          "content": {
            "type": "SEQ",
            "members": [
              {
                "type": "STRING",
                "value": "."
              },
              {
                "type": "SYMBOL",
                "name": "identifier"
              }
            ]
          }
        }
      ]
    },
    "start_delimiter": {
      "type": "STRING",
      "value": "{{"
    },
    "end_delimiter": {
      "type": "STRING",
      "value": "}}"
    },
    "_start_tag_name": {
      "type": "PATTERN",
      "value": "[^\\s}]+"
    },
    "_end_tag_name": {
      "type": "PATTERN",
      "value": "[^\\s}]+"
    },
    "_comment_content": {
      "type": "PATTERN",
      "value": "([^}]|}[^}])*"
    },
    "_identifier_content": {
      "type": "PATTERN",
      "value": "[^\\s}\\.#\\^\\/!><\\$&\\{]+"
    },
    "text": {
      "type": "CHOICE",
      "members": [
        {
          "type": "PATTERN",
          "value": "([^{}]|\\{[^{]|\\}[^}])*[^\\{\\}\\s]([^{}]|\\{[^{]|\\}[^}])*"
        },
        {
          "type": "PATTERN",
          "value": "\\{"
        },
        {
          "type": "PATTERN",
          "value": "\\}"
        }
      ]
    }
  },
  "extras": [
    {
      "type": "PATTERN",
      "value": "\\s"
    }
  ],
  "conflicts": [],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}